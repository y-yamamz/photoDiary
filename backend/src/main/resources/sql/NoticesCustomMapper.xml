<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.photo.backend.db.mapper.NoticesCustomMapper">

  <!--
    指定ユーザー向けのお知らせ一覧を返す。
    全体配信（target_user_id IS NULL）と
    当該ユーザー宛の個人通知（target_user_id = userId）を含む。
    新しい順で返す。
  -->
  <select id="selectForUserWithBLOBs" resultMap="com.photo.backend.db.mapper.NoticesMapper.ResultMapWithBLOBs">
    SELECT notice_id, target_user_id, title, created_at, updated_at, body
    FROM notices
    WHERE target_user_id IS NULL
       OR target_user_id = #{userId,jdbcType=BIGINT}
    ORDER BY created_at DESC
  </select>

</mapper>
