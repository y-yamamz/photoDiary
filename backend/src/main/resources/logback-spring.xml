<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- application.yml から読み込むプロパティ -->
  <!-- logging.log.path  : ログ出力先ディレクトリ (デフォルト: logs) -->
  <!-- logging.log.sql   : SQLログレベル         (デフォルト: OFF)  -->
  <springProperty scope="context" name="LOG_PATH"  source="logging.log.path"  defaultValue="logs"/>
  <springProperty scope="context" name="SQL_LEVEL" source="logging.log.sql"   defaultValue="OFF"/>

  <!-- ============================================================
       パターン定義
       ============================================================ -->
  <property name="CONSOLE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{40}) - %msg%n"/>
  <property name="FILE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %msg%n"/>

  <!-- ============================================================
       Appender: コンソール
       ============================================================ -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ============================================================
       Appender: アプリケーションログ (日次ローリング)
         ファイル名 : {LOG_PATH}/photodiary.log
         ローリング : photodiary.yyyy-MM-dd.log
         保持日数   : 30日
         最大サイズ : 100MB / ファイル、3GB / 全体
       ============================================================ -->
  <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/photodiary.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/photodiary.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>100MB</maxFileSize>
      <maxHistory>30</maxHistory>
      <totalSizeCap>3GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ============================================================
       Appender: SQL専用ログ (日次ローリング)
         ファイル名 : {LOG_PATH}/sql.log
         ローリング : sql.yyyy-MM-dd.log
         保持日数   : 7日
       ============================================================ -->
  <appender name="SQL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/sql.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/sql.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>50MB</maxFileSize>
      <maxHistory>7</maxHistory>
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ============================================================
       Logger: SQLログ (p6spy)
         p6spy が JDBC をラップし、パラメータ込みの実行済みSQL文を出力する
         SQL_LEVEL=DEBUG → 実行済みSQL文・実行時間を出力
         SQL_LEVEL=OFF   → 出力しない (デフォルト)
       ============================================================ -->
  <logger name="p6spy" level="${SQL_LEVEL}" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="SQL_FILE"/>
    <appender-ref ref="APP_FILE"/>
  </logger>

  <!-- ============================================================
       Root Logger
       ============================================================ -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="APP_FILE"/>
  </root>

</configuration>
