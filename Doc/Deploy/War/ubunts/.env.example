# =============================================================
# PhotoDiary WAR デプロイ用 環境設定 [Ubuntu + NAS マウント版]
# このファイルをコピーして .env を作成してください
#   cp .env.example .env
# =============================================================

# =====================
# MySQL 接続設定
# =====================
MYSQL_URL=jdbc:mysql://mysql84:3306/photodb?useSSL=false&serverTimezone=Asia/Tokyo&allowPublicKeyRetrieval=true
MYSQL_USER=yama
MYSQL_PASSWORD=yama

# =====================
# フロントエンドの公開ポート（デフォルト: 80）
# =====================
FRONTEND_PORT=80

# =====================
# 画像フォルダのパス設定
# Ubuntu ホスト側で NAS が /mnt/homedir にマウント済みの場合、
# その配下の PhotoDiary フォルダを指定する。
# =====================
IMAGE_LOCAL_PATH=/mnt/homedir/PhotoDiary

# =====================
# 管理者シークレットキー（パスワードリセット用）
# 本番環境では必ず強力なキーに変更してください
# =====================
ADMIN_SECRET=photo-admin-secret-change-me

# =====================
# CORS 許可オリジン（カンマ区切りで複数指定可）
# Cloudflare カスタムドメインで公開する場合は必須
# 例: ALLOWED_ORIGINS=https://photos.example.com
# ワイルドカード例: ALLOWED_ORIGINS=https://*.example.com
# 本番時に有効にしてください
# =====================
ALLOWED_ORIGINS=https://photodiary.nexoraapp.dev
