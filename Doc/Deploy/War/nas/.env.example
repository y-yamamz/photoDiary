# =============================================================
# PhotoDiary WAR デプロイ用 環境設定 [NAS版]
# このファイルをコピーして .env を作成してください
#   copy .env.example .env
# =============================================================

# =====================
# MySQL 接続設定
# =====================
MYSQL_URL=jdbc:mysql://192.168.0.3:3306/photodb?useSSL=false&serverTimezone=Asia/Tokyo
MYSQL_USER=yama
MYSQL_PASSWORD=yama

# =====================
# フロントエンドの公開ポート（デフォルト: 80）
# =====================
FRONTEND_PORT=80

# =====================
# NAS 接続設定（CIFS マウント用）
# Docker Desktop は WSL2 上で動作するため UNC パス直接マウントは不可。
# CIFS named volume を使い Docker が直接 NAS に SMB 接続する。
# =====================
# NAS の共有パス（//IPアドレス/共有名/サブフォルダ）
IMAGE_VOLUME_PATH=//192.168.0.5/homedir/PhotoDiary
# NAS の IP アドレス（addr オプションに使用）
NAS_ADDR=192.168.0.5
# NAS 認証情報（ゲストアクセス可能な場合は空のままでOK）
NAS_USER=
NAS_PASSWORD=
