# =============================================================
# PhotoDiary WAR デプロイ用 環境設定 [外部HDD (Yドライブ) 版]
# このファイルをコピーして .env を作成してください
#   copy .env.example .env
# =============================================================

# =====================
# MySQL 接続設定
# =====================
MYSQL_URL=jdbc:mysql://192.168.0.10:3306/photodb?useSSL=false&serverTimezone=Asia/Tokyo
MYSQL_USER=yama
MYSQL_PASSWORD=yama

# =====================
# フロントエンドの公開ポート（デフォルト: 80）
# =====================
FRONTEND_PORT=80

# =====================
# 外部HDD (Yドライブ) パス設定
# Docker Desktop の Settings > Resources > File sharing に
# 対象フォルダを追加してから起動すること。
# =====================
# 画像フォルダの Windows パス（スラッシュ区切りで記載）
IMAGE_LOCAL_PATH=Y:/PhotoDiary
