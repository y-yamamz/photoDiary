# =============================================================
# PhotoDiary Docker 環境設定ファイル (Windows Docker Desktop 用)
# このファイルを .env にコピーして編集してください
#   copy .env.example .env   (コマンドプロンプト)
#   cp .env.example .env     (PowerShell / WSL2)
# =============================================================

# =====================
# MySQL接続設定
# =====================
MYSQL_URL=jdbc:mysql://192.168.0.3:3306/photodb?useSSL=false&serverTimezone=Asia/Tokyo
MYSQL_USER=yama
MYSQL_PASSWORD=yama

# =====================
# フロントエンドの公開ポート（デフォルト: 80）
# 80番が使用中の場合は変更する（例: 8080）
# =====================
FRONTEND_PORT=80

# =====================
# NAS接続設定（CIFSマウント用）
# 認証不要（ゲストアクセス）の場合は空のままでOK
# =====================
NAS_USER=
NAS_PASSWORD=
